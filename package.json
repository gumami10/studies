{
  "name": "ctal-at-study-guide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm run convert && pnpm run generate-seo && pnpm run optimize-og",
    "dev": "vite",
    "prebuild": "pnpm run convert && pnpm run generate-seo && pnpm run optimize-og",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "convert": "node scripts/convert-xml.mjs",
    "generate-seo": "node scripts/generate-seo.mjs",
    "optimize-og": "node scripts/optimize-og.mjs",
    "test": "vitest run",
    "test:affected": "vitest run --changed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "heal": "node scripts/heal-tests.mjs",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "fuse.js": "^7.4.2",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@playwright/test": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.6.0"
}
