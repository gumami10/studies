# Public site URL used for canonical links, OG `og:url`, sitemap entries, and JSON-LD.
# Override per environment: `VITE_SITE_URL=https://your.domain pnpm build`.
VITE_SITE_URL=https://example.com

# OpenCode Go API key (read by opencode CLI for `pnpm heal` self-healing script).
# Get it at https://opencode.ai/auth → OpenCode Go → Create API Key.
# CI uses the GitHub secret OPENCODE_API_KEY instead; this is for local dev only.
OPENCODE_API_KEY=
